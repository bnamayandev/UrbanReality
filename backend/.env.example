API_PORT=8001

# ── NeMoTron / LLM (for impact analysis + chat) ───────────────────────────────
# Option A: Ollama local (DGX Spark)
MODEL_URL=http://localhost:11434/v1
MODEL_NAME=nemotron-3-super:latest


# ── Image generation (for building previews) ──────────────────────────────────
# Primary renderer: Gemini image (gemini-3.1-flash-image)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Optional override (aistudio.google.com/app/apikey)
OPENAI_API_KEY=your_openai_api_key_here

# 3. FLUX.1-schnell — Together AI (api.together.ai)
TOGETHER_API_KEY=your_together_api_key_here

# 4. SDXL — NVIDIA Build (fallback, uses NGC_API_KEY above)
NGC_API_KEY=your_ngc_api_key_here

# ── 3D generation ────────────────────────────────────────────────────────────
# Image→3D runs locally. Two backends, each in its own venv. Both need HF_TOKEN.
HF_TOKEN=your_huggingface_token_here
# RENDERER_3D=hunyuan              # hunyuan (default, high-detail) | sf3d (light, textured)

# Hunyuan3D-2mini — rendering-pipeline/hunyuan3d-2/.venv-hunyuan. ~17x SF3D
# geometry. NOTE: Tencent Hunyuan NON-COMMERCIAL license.
# HUNYUAN_OCTREE=256              # geometry detail (16-512); higher = finer + more VRAM/time
# HUNYUAN_STEPS=30               # diffusion steps
# HUNYUAN_GUIDANCE=5.0
# HUNYUAN_MAX_FACES=80000        # decimate to this face budget for web delivery (-1 = keep raw)
# HUNYUAN_TEXTURE=1              # 1 = paint a texture (multiview), 0 = untextured grey massing
# Texture needs the texgen CUDA ext compiled ONCE in .venv-hunyuan (gcc-12 for CUDA 12.0):
#   cd rendering-pipeline/hunyuan3d-2/hy3dgen/texgen
#   CC=gcc-12 CXX=g++-12 NVCC_PREPEND_FLAGS='-ccbin g++-12' TORCH_CUDA_ARCH_LIST=8.6 \
#     ../../../.venv-hunyuan/bin/python custom_rasterizer/setup.py install
#   ../../../.venv-hunyuan/bin/python differentiable_renderer/setup.py install

# Stable Fast 3D — rendering-pipeline/stable-fast-3d/.venv-sf3d. Gated on HF:
# accept the license at https://huggingface.co/stabilityai/stable-fast-3d
# SF3D_REMESH=none                 # none | triangle | quad
# SF3D_VERTEX_COUNT=-1             # target vertex count for low-poly output (-1 = model default)
# SF3D_FOREGROUND_RATIO=0.85       # how much of the frame the building fills before reconstruction
# SF3D_TEXTURE_RES=1024            # texture atlas res; main visual lever. 1024 peaks ~6.2GB on 8GB.
                                   # 1536 needs the allocator flag below (otherwise OOMs by ~250MB):
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ── Other ─────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=your_mapbox_token_here
