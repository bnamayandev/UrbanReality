# Local PostgreSQL (DGX default)
DATABASE_URL=postgresql://postgres:postgres@localhost/urbanforge
# Supabase cloud (use this if not on DGX)
# DATABASE_URL=postgresql://postgres:nvidia-hack1@db.ufmlqbgwxkxpgotuvfcu.supabase.co:5432/postgres

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Settings → API → JWT Secret  (used to verify user tokens on the backend)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

API_PORT=8001

# ── NeMoTron / LLM (for impact analysis + chat) ───────────────────────────────
# Option A: Ollama local (DGX Spark)
MODEL_URL=http://localhost:11434/v1
MODEL_NAME=nemotron-3-super:latest

# Option B: NVIDIA Build API
# MODEL_URL=https://integrate.api.nvidia.com/v1
# MODEL_NAME=nvidia/nemotron-mini-4b-instruct
# NGC_API_KEY=your_ngc_api_key_here

NEMORON_URL=http://localhost:11434

# ── Image generation (for building previews) ──────────────────────────────────
# Rehan's AI renderer tries these in priority order:
# 1. DALL-E 3 — best quality (platform.openai.com → API keys)
OPENAI_API_KEY=your_openai_api_key_here

# 2. Imagen 3 — Google (aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# 3. FLUX.1-schnell — Together AI (api.together.ai)
TOGETHER_API_KEY=your_together_api_key_here

# 4. SDXL — NVIDIA Build (fallback, uses NGC_API_KEY above)
NGC_API_KEY=your_ngc_api_key_here

# ── TRELLIS.2 / GX10 ─────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here
GX10_HOST=100.93.45.108
GX10_USER=benjamin
GX10_PORT=22

# ── Other ─────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=your_mapbox_token_here
