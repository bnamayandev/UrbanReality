API_PORT=8001

# ── NeMoTron / LLM (for impact analysis + chat) ───────────────────────────────
# Option A: Ollama local (DGX Spark)
MODEL_URL=http://localhost:11434/v1
MODEL_NAME=nemotron-3-super:latest


# ── Image generation (for building previews) ──────────────────────────────────
# Primary renderer: Gemini image (gemini-3.1-flash-image)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Optional override (aistudio.google.com/app/apikey)
OPENAI_API_KEY=your_openai_api_key_here

# 3. FLUX.1-schnell — Together AI (api.together.ai)
TOGETHER_API_KEY=your_together_api_key_here

# 4. SDXL — NVIDIA Build (fallback, uses NGC_API_KEY above)
NGC_API_KEY=your_ngc_api_key_here

# ── 3D generation (Stable Fast 3D) ───────────────────────────────────────────
# Image→3D runs locally via Stable Fast 3D in its own venv
# (rendering-pipeline/stable-fast-3d/.venv-sf3d). The model is gated on HF —
# accept the license at https://huggingface.co/stabilityai/stable-fast-3d
HF_TOKEN=your_huggingface_token_here
# RENDERER_3D=sf3d                 # only sf3d is supported
# SF3D_REMESH=none                 # none | triangle | quad
# SF3D_VERTEX_COUNT=-1             # target vertex count for low-poly output (-1 = model default)
# SF3D_TEXTURE_RES=1024

# ── Other ─────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=your_mapbox_token_here
