# Local data directory (relative to project root)
DATA_DIR=./data

# Date filter for building permits (YYYY-MM-DD)
PERMITS_FILTER_DATE=2020-01-01

# Set to 1 to force re-download of all datasets (ignores cache)
FORCE_REFRESH=0

# Image generation (for building previews — tried in priority order)
# 1. DALL-E 3 — best quality (platform.openai.com → API keys)
OPENAI_API_KEY=your_openai_api_key_here

# 2. Imagen 3 + Gemini — Google (aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Local model server (Ollama — nemotron-3-super)
MODEL_URL=http://localhost:11434/v1
MODEL_NAME=nemotron-3-super:latest
NGC_API_KEY=not-needed
